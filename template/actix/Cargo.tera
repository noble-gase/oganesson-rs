[workspace]
resolver = "3"
members = {{ members }}

[workspace.package]
description = "Rust api build with ogx"
version = "0.0.1"
edition = "2024"
authors = ["ShengHui <847713844@qq.com>"]
repository = "https://github.com/noble-gase/oganesson-rs"

[workspace.dependencies]
infra = { path = "infra" }
repo = { path = "repo" }
anyhow = "1"
thiserror = "2"
futures = "0.3"
tokio = { version = "1", features = ["full"] }
clap = { version = "4", features = ["derive"] }
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["json"] }
tracing-appender = "0.2"
figlet-rs = "1"
hostname = "0.4"
rand = "0.10"
base64 = "0.22"
bcrypt = "0.19"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
config = "0.15"
jiff = "0.2"
time = { version = "0.3", features = ["serde"] }
bb8 = "0.9"
uuid = { version = "1", features = ["v4"] }
sqlx = { version = "0.9", features = ["runtime-tokio", "mysql", "time"] }
redis = { version = "1", features = ["tokio-comp"] }
sea-query = "1"
prometheus = { version = "0.14", features = ["process"] }
validator = { version = "0.20", features = ["derive"] }
actix-web = "4"
actix-cors = "0.7"
neon-rs = { version = "0.1", features = [
    "crypto-aes",
    "macros",
    "redis",
    "sql-mysql",
] }
